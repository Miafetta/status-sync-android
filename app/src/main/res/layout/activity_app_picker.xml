<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/appPickerRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/appPickerTopBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        android:paddingLeft="22dp"
        android:paddingRight="22dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBack"
                style="@style/ShizukuIconButton"
                android:layout_marginEnd="8dp"
                android:contentDescription="@string/settings_pick_foreground_package"
                app:icon="@drawable/ic_arrow_back_24"
                app:iconGravity="textStart" />

            <TextView
                style="@style/ShizukuPageTitle"
                android:text="@string/settings_pick_foreground_package" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="22dp"
        android:paddingTop="8dp"
        android:paddingEnd="22dp"
        android:paddingBottom="10dp">

        <com.google.android.material.textfield.TextInputLayout
            style="@style/ShizukuSearchInputLayout"
            android:hint="@string/settings_app_search"
            app:endIconMode="clear_text">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/inputAppSearch"
                style="@style/ShizukuTextInputEditText"
                android:inputType="text"
                android:singleLine="true" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switchShowSystemApps"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:minHeight="40dp"
            android:text="@string/settings_show_system_apps"
            android:textColor="?attr/colorOnSurface"
            android:textSize="16sp"
            android:textStyle="normal"
            app:thumbTint="@color/app_picker_switch_thumb"
            app:trackTint="@color/app_picker_switch_track" />
    </LinearLayout>

    <ListView
        android:id="@+id/listApps"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:divider="@null"
        android:paddingBottom="16dp"
        android:scrollbarStyle="outsideOverlay" />
</LinearLayout>
